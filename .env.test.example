# Copy this file to .env.test and fill in real values.
# .env.test is gitignored — never commit it.

# Staging webhook base URL
N8N_WEBHOOK_BASE=https://flows-staging.caiacdigital.com

# Webhook header auth key (value of x-webhook-key header)
WEBHOOK_HEADER_KEY=your-webhook-key-here

# Postgres connection string (shared DB — both staging and prod point here)
DATABASE_URL=postgresql://caiac:password@host:5432/caiac

# Test client slug — henderson is the designated test client
TEST_CLIENT_SLUG=henderson

# Test user credentials — test@caiacdigital.com / CaiacTest2026! (role: client_user, safe to modify)
TEST_USER_EMAIL=test@caiacdigital.com
TEST_USER_PASSWORD=CaiacTest2026!

# Role-based test users — existing Henderson users with these roles
# Used by tests/workflows/document-permissions.test.ts
# Tests that use unconfigured roles will skip with a console.warn rather than fail
TEST_USER_STAFF_EMAIL=
TEST_USER_STAFF_PASSWORD=
TEST_USER_ADMIN_EMAIL=
TEST_USER_ADMIN_PASSWORD=
TEST_USER_OWNER_EMAIL=
TEST_USER_OWNER_PASSWORD=

# CAIAC platform staff credentials — required for document ingest/delete in content-level tests
# Use your own CAIAC login (is_caiac_staff=true), NOT a Henderson client user
CAIAC_STAFF_EMAIL=
CAIAC_STAFF_PASSWORD=

# Optional: a known chat session_id that has at least one message
# Used by promote-dismiss.test.ts happy-path tests. Get from the client dashboard history view.
TEST_HISTORY_SESSION_ID=
