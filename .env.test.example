# Copy this file to .env.test and fill in real values.
# .env.test is gitignored — never commit it.
# To push values to GitHub Actions: gh secret set --repo cewall0/caiac-n8n-workflows --env-file .env.test

# Postgres connection string (shared DB — both staging and prod point here)
# claude_readonly user has SELECT on all caiac.* tables
DATABASE_URL=postgresql://claude_readonly:<password>@<vps-host>:5432/caiac

# Test client slug — henderson is the designated test client
TEST_CLIENT_SLUG=henderson

# Client-role test user — safe to modify in staging
TEST_USER_EMAIL=test@caiacdigital.com
TEST_USER_PASSWORD=

# Role-based test users — Henderson users with these roles
# Tests that use unconfigured roles will skip with console.warn rather than fail
TEST_USER_STAFF_EMAIL=
TEST_USER_STAFF_PASSWORD=
TEST_USER_ADMIN_EMAIL=
TEST_USER_ADMIN_PASSWORD=
TEST_USER_OWNER_EMAIL=
TEST_USER_OWNER_PASSWORD=

# CAIAC platform staff credentials — required for ops endpoints + document ingest/delete
# Must be a user in the caiac client (not henderson)
CAIAC_STAFF_EMAIL=
CAIAC_STAFF_PASSWORD=

# Henderson client webhook secret — used as ?key= query param in lead capture tests
TEST_CLIENT_WEBHOOK_SECRET=

# Webhook key for intake endpoint (x-webhook-key header) — not currently enforced
WEBHOOK_HEADER_KEY=

# Chat staging webhook path
CHAT_PATH=caiac/chat/v26-staging

# Optional: a known chat session_id that has at least one message
# promote-dismiss.test.ts seeds its own session automatically; this var is only needed
# when running promote-dismiss standalone without the rest of the suite.
TEST_HISTORY_SESSION_ID=
