    {
      "id": "prep-auth-post",
      "name": "Prepare Auth (POST)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 300],
      "parameters": {
        "jsCode": "const req = $input.first().json;\nreturn [{ json: {\n  token: (req.headers.authorization || '').replace(/^Bearer\\s+/i, '') || req.body?.token,\n  timestamp: req.headers['x-caiac-timestamp'],\n  signature: req.headers['x-caiac-signature']\n}}];"
      }
    },
    {
      "id": "call-auth-post",
      "name": "Call Full Auth (POST)",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.3,
      "position": [440, 300],
      "parameters": {
        "workflowId": { "__rl": true, "value": "XWbmBI9NYdwK80eg", "mode": "id" },
        "workflowInputs": {
          "mappingMode": "defineBelow",
          "value": { "token": "={{ $json.token }}", "timestamp": "={{ $json.timestamp }}", "signature": "={{ $json.signature }}" },
          "schema": [
            { "id": "1", "displayName": "token", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true },
            { "id": "2", "displayName": "timestamp", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true },
            { "id": "3", "displayName": "signature", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "check-auth-post",
      "name": "Check Staff Auth (POST)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 300],
      "parameters": {
        "jsCode": "const auth = $input.first().json;\nif (!auth.is_caiac_staff) throw new Error('Forbidden: CAIAC staff access required');\nconst body = $('Receive POST Request').first().json.body;\nif (!body?.slug) throw new Error('Missing required field: slug');\nreturn [{ json: {\n  slug: body.slug,\n  google_review_link: body.google_review_link ?? null,\n  facebook_review_link: body.facebook_review_link ?? null,\n  review_notify_email: body.review_notify_email ?? null\n}}];"
      }
    },
    {
      "id": "update-cpc",
      "name": "Update Platform Config",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [880, 300],
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE caiac.client_platform_config\nSET\n  google_review_link = CASE WHEN $2::text IS NOT NULL THEN $2 ELSE google_review_link END,\n  facebook_review_link = CASE WHEN $3::text IS NOT NULL THEN $3 ELSE facebook_review_link END,\n  review_notify_email = CASE WHEN $4::text IS NOT NULL THEN $4 ELSE review_notify_email END,\n  updated_at = NOW()\nWHERE client_slug = $1\nRETURNING client_slug;",
        "options": { "queryReplacement": "={{ [$json.slug, $json.google_review_link, $json.facebook_review_link, $json.review_notify_email] }}" }
      },
      "credentials": { "postgres": { "id": "oJ321kQrsEmHydiQ", "name": "CAIAC Postgres" } }
    },
    {
      "id": "respond-200-post",
      "name": "Respond 200 POST",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.5,
      "position": [1100, 300],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: true, slug: $json.client_slug }) }}",
        "options": { "responseCode": 200 }
      }
    },
