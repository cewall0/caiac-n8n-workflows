      "name": "Build Follow-up Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2440, 320],
      "parameters": {
        "jsCode": "const lead = $('Extract and Fingerprint Lead').first().json;\nconst config = $('Get Client Config').first().json;\n\nconst html = `<p>Hi ${lead.name},</p><p>Thanks for reaching out to ${config.from_name}! We received your inquiry and will be in touch shortly.</p>${lead.challenge ? `<p><strong>Your challenge:</strong> ${lead.challenge}</p>` : ''}<p>Best,<br>${config.from_name}</p>`;\n\nreturn [{ json: {\n  to: lead.email,\n  from: config.from_email,\n  subject: `Thanks for reaching out, ${lead.name.split(' ')[0]}!`,\n  html\n} }];"
      }
    },
