        "operation": "executeQuery",
        "query": "SELECT\n  id              AS client_id,\n  slug            AS client_slug,\n  webhook_secret,\n  config->'lead_capture'->>'notify_email' AS notify_email,\n  config->'lead_capture'->>'sheet_id'     AS sheet_id,\n  COALESCE(config->'lead_capture'->>'from_name',  'CAIAC Digital')        AS from_name,\n  COALESCE(config->'lead_capture'->>'from_email', 'caiacgroup@gmail.com') AS from_email\nFROM caiac.clients\nWHERE slug = '{{ $('Receive Lead Form').item.json.query.slug ?? 'caiac' }}'\n  AND active = true\nLIMIT 1",
        "options": {}
      },
