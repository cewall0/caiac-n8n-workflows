    {
      "parameters": {
        "jsCode": "const fields = $('Receive Lead Form').first().json.body.data.fields;\nconst config  = $('Get Client Config').first().json;\n\nconst getField = (label) => {\n  const f = fields.find(f => f.label === label);\n  if (!f) return '';\n  if (f.type === 'DROPDOWN' && f.options) {\n    const vals = Array.isArray(f.value) ? f.value : [f.value];\n    const opt  = f.options.find(o => vals.includes(o.id));\n    return opt ? opt.text : '';\n  }\n  return f.value ?? '';\n};\n\nconst email = getField('Email').toLowerCase().trim();\n\n// Deterministic fingerprint from email\nlet state = email.split('').reduce((acc, ch) => (Math.imul(acc, 31) + ch.charCodeAt(0)) | 0, 0x811c9dc5);\nlet hex = '';\nwhile (hex.length < 32) {\n  state = (Math.imul(state, 1664525) + 1013904223) | 0;\n  hex  += (state >>> 0).toString(16).padStart(8, '0');\n}\nconst fingerprint = hex.slice(0, 32);\n\nreturn [{ json: {\n  client_id:     config.client_id,\n  client_slug:   config.client_slug,\n  notify_email:  config.notify_email,\n  sheet_id:      config.sheet_id,\n  from_name:     config.from_name,\n  from_email:    config.from_email,\n  name:          getField('Full Name'),\n  email,\n  phone:         getField('Phone'),\n  business_type: getField('Business Type'),\n  business_name: getField('Business Name'),\n  challenge:     getField('What is your biggest business challenge?'),\n  how_heard:     getField('How did you hear about us?'),\n  submitted_at:  $('Receive Lead Form').first().json.body.createdAt,\n  fingerprint,\n} }];"
      },
      "id": "extract",
      "name": "Extract and Fingerprint Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 208]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  (SELECT id FROM caiac.leads\n   WHERE client_id = '{{ $('Extract and Fingerprint Lead').first().json.client_id }}'::uuid\n     AND intake_fingerprint = '{{ $('Extract and Fingerprint Lead').first().json.fingerprint }}'\n   LIMIT 1) AS lead_id,\n  (SELECT qualification_score FROM caiac.leads\n   WHERE client_id = '{{ $('Extract and Fingerprint Lead').first().json.client_id }}'::uuid\n     AND intake_fingerprint = '{{ $('Extract and Fingerprint Lead').first().json.fingerprint }}'\n   LIMIT 1) AS qualification_score,\n  (SELECT qualification_score_reason FROM caiac.leads\n   WHERE client_id = '{{ $('Extract and Fingerprint Lead').first().json.client_id }}'::uuid\n     AND intake_fingerprint = '{{ $('Extract and Fingerprint Lead').first().json.fingerprint }}'\n   LIMIT 1) AS qualification_score_reason",
        "options": {}
      },
