      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2920, 320],
      "parameters": {
        "jsCode": "const lead = $('Extract and Fingerprint Lead').first().json;\nconst config = $('Get Client Config').first().json;\nconst score = $('Score Lead').first().json;\n\nconst html = `<h2>New Lead: ${lead.name}</h2><table><tr><td><b>Email:</b></td><td>${lead.email}</td></tr><tr><td><b>Phone:</b></td><td>${lead.phone || 'N/A'}</td></tr><tr><td><b>Business:</b></td><td>${lead.business_name || 'N/A'}</td></tr><tr><td><b>Type:</b></td><td>${lead.business_type || 'N/A'}</td></tr><tr><td><b>Challenge:</b></td><td>${lead.challenge || 'N/A'}</td></tr><tr><td><b>How heard:</b></td><td>${lead.how_heard || 'N/A'}</td></tr><tr><td><b>Score:</b></td><td>${score.qualification_score ?? 'N/A'}/10 — ${score.qualification_score_reason || ''}</td></tr></table>`;\n\nreturn [{ json: {\n  to: config.notify_email,\n  from: config.from_email,\n  subject: `New lead: ${lead.name} (Score: ${score.qualification_score ?? 'N/A'}/10)`,\n  html\n} }];"
      }
    },
