    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst isNew = input.lead_sheet_tab === 'Leads';\nconst match_column = isNew ? 'Phone' : 'Source Ref';\nreturn [{ json: {\n  lead_sheet_id: input.lead_sheet_id,\n  lead_sheet_tab: 'Review Status',\n  match_column,\n  match_value: input.source_ref,\n  fields: input.fields\n} }];"
      },
