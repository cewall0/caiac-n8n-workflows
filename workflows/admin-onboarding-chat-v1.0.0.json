    {
      "id": "parse-body",
      "name": "Parse Body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, -160],
      "parameters": {
        "jsCode": "const req = $('Receive Request').first().json;\nconst body = req.body || {};\nconst message = (body.message || '').trim();\nconst session_id = (body.session_id || '').trim();\nif (!message) return [{ json: { valid: false, chatInput: '', session_id, error: 'Missing required field: message' } }];\nreturn [{ json: { valid: true, chatInput: message, session_id, error: null } }];"
      }
    },
