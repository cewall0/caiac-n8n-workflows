      "name": "Fetch Client",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [1320, -320],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, slug FROM caiac.clients WHERE slug = $1 AND active = true LIMIT 1",
        "options": { "queryReplacement": "={{ [$json.slug] }}" }
      },
      "credentials": { "postgres": { "name": "CAIAC Postgres" } }
    },
