      "id": "normalize-client",
      "name": "Normalize Client",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1540, -320],
      "parameters": {
        "jsCode": "const items = $input.all();\nif (items.length === 0 || !items[0].json.id) {\n  return [{ json: { found: false, id: null, slug: null } }];\n}\nreturn [{ json: { found: true, id: items[0].json.id, slug: items[0].json.slug } }];"
      }
    },
