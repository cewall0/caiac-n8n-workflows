      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1980, -440],
      "parameters": {
        "jsCode": "const client = $('Normalize Client').first().json;\nconst validated = $('Parse + Validate').first().json;\nreturn [{ json: { client_id: client.id, client_slug: client.slug, step: validated.step, params: validated.params } }];"
      }
    },
