      "position": [864, 624]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT u.id, u.password_hash\nFROM caiac.users u\nWHERE u.id = '{{ $('Call Full Auth').item.json.user_id }}'\nLIMIT 1",
        "options": {}
      },
