    {
      "id": "ah-build-response-01",
      "name": "Build Health Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2016, 300],
      "parameters": {
        "jsCode": "function svc(name) {\n  try {\n    const r = $(name).first().json;\n    if (r && r.error) return { status: 'down', error: r.error };\n    return { status: 'up' };\n  } catch (e) {\n    return { status: 'down', error: e.message };\n  }\n}\n\nconst services = {\n  postgres: svc('Check Postgres'),\n  qdrant: svc('Check Qdrant'),\n  ollama: svc('Check Ollama'),\n  reranker: svc('Check Reranker'),\n  hmac_verifier: svc('Check HMAC Verifier')\n};\n\nconst allUp = Object.values(services).every(s => s.status === 'up');\n\nreturn [{ json: {\n  status: allUp ? 'healthy' : 'degraded',\n  checked_at: new Date().toISOString(),\n  services\n} }];"
      }
    },
    {
      "id": "ah-send-response-01",
      "name": "Send Health Response",
      "type": "n8n-nodes-base.respondToWebhook",
