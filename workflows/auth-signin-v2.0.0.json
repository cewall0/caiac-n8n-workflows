      "position": [1792, 656],
      "webhookId": "7ea2789d-7aa9-47c3-8d37-2f4b2716dd45"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  u.id, u.name, u.email, u.role, u.password_hash, u.must_change_password,\n  u.active as user_active, u.is_caiac_staff, c.id as client_id, c.slug, c.active as client_active,\n  c.webhook_secret, c.jwt_secret, c.config,\n  CASE WHEN u.id IS NOT NULL AND c.id IS NOT NULL THEN true ELSE false END as user_found\nFROM (SELECT 1) AS dummy\nLEFT JOIN caiac.clients c ON c.slug = $1\nLEFT JOIN caiac.users u ON u.email = $2 AND u.client_id = c.id\nLIMIT 1",
        "options": {
          "queryReplacement": "=[\"{{ $('Receive Request').item.json.body.slug }}\", \"{{ $('Receive Request').item.json.body.email }}\"]"
        }
      },
