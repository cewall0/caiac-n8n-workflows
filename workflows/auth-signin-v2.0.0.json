    },
    {
      "parameters": {
        "jsCode": "return [{\n  json: {\n    token: $('Generate JWT').item.json.token,\n    session_id: $('Generate Session IDs').item.json.sid,\n    webhook_secret: $('Look Up User').item.json.webhook_secret,\n    must_change_password: $('Look Up User').item.json.must_change_password,\n    user: {\n      name: $('Look Up User').item.json.name,\n      email: $('Look Up User').item.json.email,\n      role: $('Look Up User').item.json.role\n    }\n  }\n}];"
      },
