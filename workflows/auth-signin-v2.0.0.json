      "id": "gen-session-ids-001",
      "name": "Generate Session IDs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3200, 520],
      "parameters": {
        "jsCode": "function uuid() {\n  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {\n    const r = Math.random() * 16 | 0;\n    return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);\n  });\n}\nreturn [{ json: { jti: uuid(), sid: uuid() } }];"
      }
    },
