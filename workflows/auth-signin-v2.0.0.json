            { "name": "user_id", "value": "={{ $('Look Up User').item.json.id }}" },
            { "name": "client_id", "value": "={{ $('Look Up User').item.json.client_id }}" },
            { "name": "slug", "value": "={{ $('Look Up User').item.json.slug }}" },
            { "name": "role", "value": "={{ $('Look Up User').item.json.role }}" },
            { "name": "email", "value": "={{ $('Look Up User').item.json.email }}" },
            { "name": "jwt_secret", "value": "={{ $('Look Up User').item.json.jwt_secret }}" },
            { "name": "jti", "value": "={{ $('Generate Session IDs').item.json.jti }}" },
            { "name": "sid", "value": "={{ $('Generate Session IDs').item.json.sid }}" },
            { "name": "is_caiac_staff", "value": "={{ $('Look Up User').item.json.is_caiac_staff === true }}" },
            { "name": "name", "value": "={{ $('Look Up User').item.json.name }}" }
          ]
        },
